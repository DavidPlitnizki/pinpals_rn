{
  "expo": {
    "name": "Pinpals",
    "slug": "pinpals",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pinpals",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.davidplit.pinpals",
      "newArchEnabled": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "newArchEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.davidplit.pinpals",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "fonts": [
      "./assets/fonts/Inter_400Regular.ttf",
      "./assets/fonts/Inter_500Medium.ttf",
      "./assets/fonts/Inter_600SemiBold.ttf",
      "./assets/fonts/Inter_700Bold.ttf",
      "./assets/fonts/Nunito_400Regular.ttf",
      "./assets/fonts/Nunito_600SemiBold.ttf",
      "./assets/fonts/Nunito_700Bold.ttf",
      "./assets/fonts/Nunito_800ExtraBold.ttf"
    ],
    "plugins": [
      "expo-router",
      "@rnmapbox/maps",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Pinpals to use your location to centre the map."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f8f4aa",
          "image": "./assets/images/splash-screen.png",
          "resizeMode": "cover",
          "enableFullScreenImage_legacy": true
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "expo-build-properties",
      "./plugins/withModularHeaders"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "01f09958-0a03-4caa-8b93-d142286345a1"
      }
    }
  }
}
