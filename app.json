{
  "expo": {
    "name": "pinpals_rn",
    "slug": "pinpals_rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/splash-icon.png",
    "scheme": "pinpalsrn",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.davidplit.pinpals-rn",
      "newArchEnabled": true,
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "newArchEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.davidplit.pinpals_rn"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "fonts": [
      "./assets/fonts/Inter_400Regular.ttf",
      "./assets/fonts/Inter_500Medium.ttf",
      "./assets/fonts/Inter_600SemiBold.ttf",
      "./assets/fonts/Inter_700Bold.ttf",
      "./assets/fonts/Nunito_400Regular.ttf",
      "./assets/fonts/Nunito_600SemiBold.ttf",
      "./assets/fonts/Nunito_700Bold.ttf",
      "./assets/fonts/Nunito_800ExtraBold.ttf"
    ],
    "plugins": [
      "expo-router",
      "@rnmapbox/maps",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Pinpals to use your location to centre the map."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF8F4AA",
          "image": "./assets/images/splash-screen.png",
          "resizeMode": "cover",
          "enableFullScreenImage_legacy": true
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "expo-build-properties",
      "./plugins/withModularHeaders"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
